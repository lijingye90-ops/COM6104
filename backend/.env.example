LLM_API_KEY=your_api_key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_MODEL_FAST=deepseek-v4-flash
LLM_MODEL_THINKING=deepseek-v4-pro
LLM_MODEL_BROWSER=deepseek-v4-flash
LLM_MAX_ATTEMPTS=3
LLM_RETRY_DELAY=1.0
BROWSER_HEADLESS=true
# 可选：配置 API 池，格式为 JSON 数组。主配置会先尝试，再按顺序切到池里的下一个端点。
# LLM_API_POOL=[{"api_key":"your_backup_key","base_url":"https://ark.cn-beijing.volces.com/api/coding/v3","model":"ark-code-latest"}]
# 可选：按阶段覆写模型策略，例如：
# LLM_STAGE_AGENT_ORCHESTRATOR_MODEL=deepseek-v4-pro
# LLM_STAGE_AGENT_ORCHESTRATOR_REASONING=high
# LLM_STAGE_AGENT_ORCHESTRATOR_THINKING=true
# 兼容旧配置：如果没设置 LLM_API_KEY，会回退到 ZHIPUAI_API_KEY
ZHIPUAI_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
